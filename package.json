{
  "name": "ia-na-saude",
  "version": "0.1.0",
  "private": true,
  "description": "IA na Saúde · curso aberto sobre inteligência artificial para profissionais de saúde (pt-PT).",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "clean": "rm -rf _site",
    "build:css": "postcss src/assets/css/global.css -o _site/assets/css/global.css",
    "build:components": "vite build",
    "build:eleventy": "eleventy",
    "build": "npm run clean && npm run build:components && npm run build:css && npm run build:eleventy",
    "postbuild": "node scripts/gen-sitemap.mjs && node scripts/gen-epub.mjs",
    "prebuild": "node scripts/gen-og.mjs",
    "dev:eleventy": "eleventy --serve --port=8080 --quiet",
    "dev:css": "postcss src/assets/css/global.css -o _site/assets/css/global.css --watch",
    "dev:components": "vite build --watch",
    "dev": "npm run build:components && npm run build:css && npm run dev:eleventy",
    "test": "vitest run --no-coverage",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "npm run test && npm run build && npm run test:e2e",
    "lint": "eslint .",
    "format": "prettier --write ."
  },
  "dependencies": {},
  "devDependencies": {
    "@11ty/eleventy": "^3.0.0",
    "@axe-core/playwright": "^4.11.3",
    "@fontsource/atkinson-hyperlegible-next": "^5.2.7",
    "@fontsource/instrument-sans": "^5.2.8",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/typography": "^0.5.19",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/user-event": "^14.6.1",
    "cheerio": "^1.2.0",
    "eslint": "^10.4.1",
    "jsdom": "^29.1.1",
    "jszip": "^3.10.1",
    "lit": "^3.3.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.0",
    "postcss-cli": "^11.0.0",
    "prettier": "^3.8.3",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "tailwindcss": "^4.3.0",
    "typescript": "^6.0.3",
    "vite": "^7.0.0",
    "vitest": "^4.1.8"
  }
}
