---
layout: layouts/base.njk
title: "Glossário · IA · Saúde"
description: "Glossário de termos técnicos usados na aula IA · Saúde · 20 termos com definição e ligação às secções onde aparecem."
permalink: /pt-PT/glossario/
---
{% set entries = [] %}
{% for k, v in glossary %}
  {% set _ = entries.push({ k: k, term: v.term, def: v.def, sections: v.sections }) %}
{% endfor %}

<div class="container mx-auto max-w-4xl px-4 py-16 sm:px-6 sm:py-20">
  <p class="mb-3 text-sm font-medium text-blue-600">
    <a href="{% p 'pt-PT/' %}" class="hover:underline">← voltar à aula</a>
  </p>
  <h1 class="mb-3 text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">Glossário</h1>
  <p class="mb-6 max-w-2xl text-lg text-slate-600">
    {{ entries.length }} termos técnicos que aparecem na aula. Click numa
    secção à direita para saltar para onde o termo é introduzido.
  </p>

  <div class="mb-6">
    <label class="block text-xs font-bold uppercase tracking-wider text-slate-500" for="gloss-search">procurar</label>
    <input
      type="search"
      id="gloss-search"
      placeholder="ex. softmax · RGPD · atenção"
      class="mt-1 w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-blue-500 focus:outline-none"
      aria-label="procurar termo"
    />
  </div>

  <ul id="gloss-list" class="space-y-3">
    {% set sortedEntries = entries | sort(false, true, "term") %}
    {% for g in sortedEntries %}
    <li class="gloss-item rounded-xl border border-slate-200 bg-white p-5 shadow-sm transition hover:border-blue-300"
        data-search="{{ (g.term + ' ' + g.def) | lower }}">
      <div class="flex flex-wrap items-baseline justify-between gap-2">
        <h2 class="font-display text-2xl font-bold text-slate-900">{{ g.term }}</h2>
        <div class="flex flex-wrap gap-1">
          {% for s in g.sections %}
          <a href="{% p 'pt-PT/' %}#{{ s }}" class="rounded-full border border-slate-200 bg-slate-50 px-2 py-0.5 font-mono text-[10px] text-slate-600 hover:border-blue-400 hover:text-blue-700">{{ s }}</a>
          {% endfor %}
        </div>
      </div>
      <p class="mt-2 text-sm leading-relaxed text-slate-700">{{ g.def }}</p>
    </li>
    {% endfor %}
  </ul>

  <p id="gloss-none" class="hidden mt-6 text-center text-sm text-slate-500">sem resultados</p>
</div>

<script>
  (function () {
    const input = document.getElementById("gloss-search");
    const items = document.querySelectorAll(".gloss-item");
    const none = document.getElementById("gloss-none");
    input?.addEventListener("input", function () {
      const q = input.value.trim().toLowerCase();
      let visible = 0;
      items.forEach(function (it) {
        const match = !q || (it.dataset.search || "").includes(q);
        it.style.display = match ? "" : "none";
        if (match) visible++;
      });
      if (none) none.classList.toggle("hidden", visible > 0);
    });
  })();
</script>
