---
layout: layouts/base.njk
title: "Galeria de Demos · IA · Saúde"
description: "Galeria com os 34 demos interactivos · saltar para o que interessa, sem ler a aula toda."
permalink: /pt-PT/demos/
---

<div class="container mx-auto max-w-5xl px-4 py-16 sm:px-6 sm:py-20">
  <p class="mb-3 text-sm font-medium text-blue-600">
    <a href="{% p 'pt-PT/' %}" class="hover:underline">← voltar à aula</a>
  </p>
  <h1 class="mb-3 text-4xl font-bold tracking-tight text-slate-900 sm:text-5xl">Galeria de demos</h1>
  <p class="mb-6 max-w-2xl text-lg text-slate-600">
    Saltar para o demo que interessa, sem ler a aula toda. Útil para instrutores em sala · cada cartão liga directamente para o demo na sua secção.
  </p>

  <div class="mb-6">
    <input id="demo-search" type="search" placeholder="procurar · ex. RAG, tokenizer, Bayes…" class="w-full rounded-lg border border-slate-300 px-3 py-2 focus:border-blue-500 focus:outline-none" aria-label="procurar demo" />
  </div>

  <div class="mb-6 flex flex-wrap gap-2 text-xs">
    <button type="button" data-cat="" class="cat-btn rounded-full border border-slate-700 bg-slate-900 px-3 py-1 font-medium text-white">todos</button>
    {% for c in demosCatalog.categories %}
    <button type="button" data-cat="{{ c.key }}" class="cat-btn rounded-full border border-slate-300 bg-white px-3 py-1 font-medium text-slate-700 hover:bg-slate-50">{{ c.icon }} {{ c.key }}</button>
    {% endfor %}
  </div>

  <div id="demo-grid" class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {% for d in demosCatalog.list %}
      {% set cat = null %}
      {% for c in demosCatalog.categories %}{% if c.key == d.category %}{% set cat = c %}{% endif %}{% endfor %}
      <a href="{% p 'pt-PT/' %}#{{ d.anchor }}" class="demo-card group block rounded-xl border border-slate-200 bg-white p-4 shadow-sm transition hover:-translate-y-0.5 hover:border-blue-400 hover:shadow-md" data-search="{{ (d.name + ' ' + d.summary) | lower }}" data-cat="{{ d.category }}">
        <div class="mb-2 flex items-center justify-between">
          <span class="inline-flex items-center gap-1 rounded-full bg-slate-100 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-slate-600">
            <span>{{ cat.icon if cat else "·" }}</span>{{ d.category }}
          </span>
          {% if d.highlight %}<span class="text-[10px] font-medium text-amber-600">★ {{ d.highlight }}</span>{% endif %}
        </div>
        <h3 class="mb-1 font-bold text-slate-900 group-hover:text-blue-700">{{ d.name }}</h3>
        <p class="text-sm leading-relaxed text-slate-600">{{ d.summary }}</p>
        <div class="mt-3 text-xs font-medium text-slate-500">→ secção #{{ d.anchor }}</div>
      </a>
    {% endfor %}
  </div>

  <p id="demo-none" class="mt-6 hidden text-center text-sm text-slate-500">sem resultados</p>

  <p class="mt-10 rounded-lg border border-blue-300 bg-blue-50 p-4 text-sm text-slate-700">
    <strong>Para instrutores:</strong> cada link aterra directamente no demo. Combina com modo projecção (tecla <kbd>p</kbd>) para apresentação sem distracções.
  </p>
</div>

<script>
  (function () {
    const input = document.getElementById("demo-search");
    const cards = document.querySelectorAll(".demo-card");
    const catBtns = document.querySelectorAll(".cat-btn");
    const none = document.getElementById("demo-none");
    let activeCat = "";

    function filter() {
      const q = (input && input.value || "").trim().toLowerCase();
      let visible = 0;
      cards.forEach(function (c) {
        const matchesQuery = !q || (c.dataset.search || "").includes(q);
        const matchesCat = !activeCat || c.dataset.cat === activeCat;
        const show = matchesQuery && matchesCat;
        c.style.display = show ? "" : "none";
        if (show) visible++;
      });
      if (none) none.classList.toggle("hidden", visible > 0);
    }

    input?.addEventListener("input", filter);
    catBtns.forEach(function (b) {
      b.addEventListener("click", function () {
        activeCat = b.dataset.cat || "";
        catBtns.forEach(function (x) {
          x.classList.remove("bg-slate-900", "text-white", "border-slate-700");
          x.classList.add("border-slate-300", "bg-white", "text-slate-700");
        });
        b.classList.remove("border-slate-300", "bg-white", "text-slate-700");
        b.classList.add("bg-slate-900", "text-white", "border-slate-700");
        filter();
      });
    });
  })();
</script>
