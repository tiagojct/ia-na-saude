<details class="relative">
  <summary class="cursor-pointer list-none rounded-md px-2 py-1 text-sm font-medium text-slate-500 hover:text-blue-600" aria-label="ajustes" title="ajustes">⚙</summary>
  <div class="absolute right-0 mt-2 w-60 rounded-lg border border-slate-200 bg-white p-3 shadow-lg dark-card" role="menu">
    <div class="mb-2 text-[10px] font-bold uppercase tracking-wider text-slate-500">tema</div>
    <div class="theme-toggle grid grid-cols-3 gap-1" role="radiogroup" aria-label="tema">
      <button type="button" data-theme="light" class="theme-btn rounded border border-slate-200 px-2 py-1 text-xs">☀ claro</button>
      <button type="button" data-theme="dark" class="theme-btn rounded border border-slate-200 px-2 py-1 text-xs">☾ escuro</button>
      <button type="button" data-theme="auto" class="theme-btn rounded border border-slate-200 px-2 py-1 text-xs">auto</button>
    </div>

    <div class="mt-3 mb-2 text-[10px] font-bold uppercase tracking-wider text-slate-500">tamanho · letra</div>
    <div class="font-toggle grid grid-cols-3 gap-1" role="radiogroup" aria-label="tamanho">
      <button type="button" data-fontscale="" class="font-btn rounded border border-slate-200 px-2 py-1 text-xs">A</button>
      <button type="button" data-fontscale="lg" class="font-btn rounded border border-slate-200 px-2 py-1 text-sm">A+</button>
      <button type="button" data-fontscale="xl" class="font-btn rounded border border-slate-200 px-2 py-1 text-base">AAA</button>
    </div>

    <div class="mt-3 mb-2 text-[10px] font-bold uppercase tracking-wider text-slate-500">modos</div>
    <div class="grid grid-cols-2 gap-1 text-xs">
      <button type="button" id="reading-btn" class="rounded border border-slate-200 px-2 py-1 hover:bg-blue-50">📖 leitura</button>
      <button type="button" id="projection-btn" class="rounded border border-slate-200 px-2 py-1 hover:bg-blue-50">🎤 projecção</button>
    </div>

    <div class="mt-3 mb-2 text-[10px] font-bold uppercase tracking-wider text-slate-500">hoje tenho · facilitador</div>
    <div class="slot-toggle grid grid-cols-4 gap-1" role="radiogroup" aria-label="duração da sessão">
      <button type="button" data-slot="" class="slot-btn rounded border border-slate-200 px-1 py-1 text-xs">livre</button>
      <button type="button" data-slot="30" class="slot-btn rounded border border-slate-200 px-1 py-1 text-xs">30m</button>
      <button type="button" data-slot="60" class="slot-btn rounded border border-slate-200 px-1 py-1 text-xs">60m</button>
      <button type="button" data-slot="90" class="slot-btn rounded border border-slate-200 px-1 py-1 text-xs">90m</button>
    </div>

    <div class="mt-3 mb-2 text-[10px] font-bold uppercase tracking-wider text-slate-500">notas do facilitador</div>
    <button type="button" id="notes-btn" class="w-full rounded border border-slate-200 px-2 py-1 text-xs hover:bg-blue-50">🗒 mostrar notas</button>

    <div class="mt-3 border-t border-slate-100 pt-2">
      <button type="button" id="print-btn" class="w-full rounded border border-slate-200 px-2 py-1 text-xs hover:bg-blue-50" title="{{ ui.print }}">⎙ {{ ui.print }}</button>
    </div>
  </div>
</details>
