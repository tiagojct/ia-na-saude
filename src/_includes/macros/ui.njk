{# IA · Saúde · UI macros · ported from src/components/ui/*.astro #}
{# Usage: {% from "macros/ui.njk" import objectives, aside, anchor, bridge,
   demoFrame, checkpointPrompt, mariaCloser, recap, dayMap, lectureSchema,
   pathChooser, profBridges, facilitatorNote, term %} #}

{# ---- objectives (Objectives.astro) ------------------------------------ #}
{% macro objectives(items, tag="No fim, vais conseguir") %}
<aside class="not-prose my-6 rounded-2xl border border-slate-200 bg-gradient-to-br from-blue-50/60 to-white p-5">
  <div class="mb-3 flex items-center gap-2">
    <span class="flex h-6 w-6 items-center justify-center rounded-full bg-blue-600 text-xs font-bold text-white">✓</span>
    <span class="text-xs font-bold uppercase tracking-wider text-blue-700">{{ tag }}</span>
  </div>
  <ul class="space-y-2 text-sm text-slate-700">
    {% for item in items %}
    <li class="flex items-start gap-2 leading-relaxed">
      <span class="mt-1.5 inline-block h-1.5 w-1.5 shrink-0 rounded-full bg-blue-500"></span>
      <span>{{ item | safe }}</span>
    </li>
    {% endfor %}
  </ul>
</aside>
{% endmacro %}

{# ---- aside (Aside.astro) · tones: neutral|warn|ok|info|danger ---------- #}
{% macro aside(title, tone="neutral", icon="") %}
{% set styles = {
  neutral: { border: "border-slate-300", bg: "bg-slate-50", iconBg: "bg-slate-200 text-slate-700", defaultIcon: "·" },
  warn:    { border: "border-amber-400", bg: "bg-amber-50/70", iconBg: "bg-amber-200 text-amber-900", defaultIcon: "⚠" },
  ok:      { border: "border-green-400", bg: "bg-green-50/70", iconBg: "bg-green-200 text-green-900", defaultIcon: "✓" },
  info:    { border: "border-blue-400", bg: "bg-blue-50/70", iconBg: "bg-blue-200 text-blue-900", defaultIcon: "i" },
  danger:  { border: "border-red-500", bg: "bg-red-50/70", iconBg: "bg-red-200 text-red-900", defaultIcon: "✗" }
} %}
{% set s = styles[tone] %}
<aside class="not-prose my-6 rounded-xl border-l-4 {{ s.border }} {{ s.bg }} p-5">
  <div class="mb-2 flex items-center gap-2">
    <span class="flex h-5 w-5 items-center justify-center rounded-full text-xs font-bold {{ s.iconBg }}">{{ icon or s.defaultIcon }}</span>
    <span class="font-bold text-slate-900">{{ title }}</span>
  </div>
  <div class="text-sm leading-relaxed text-slate-700">{{ caller() }}</div>
</aside>
{% endmacro %}

{# ---- anchor (Anchor.astro) · types: evidence|case|context -------------- #}
{% macro anchor(tag, type="evidence") %}
{% set styles = {
  evidence: { border: "border-emerald-300", bg: "bg-emerald-50/40", icon: "📄", iconBg: "bg-emerald-100 text-emerald-800" },
  case:     { border: "border-blue-300", bg: "bg-blue-50/40", icon: "🩺", iconBg: "bg-blue-100 text-blue-800" },
  context:  { border: "border-slate-300", bg: "bg-slate-50/40", icon: "📌", iconBg: "bg-slate-100 text-slate-700" }
} %}
{% set s = styles[type] %}
<aside class="not-prose my-6 overflow-hidden rounded-xl border-2 {{ s.border }} {{ s.bg }}">
  <div class="flex items-start gap-3 p-4">
    <div class="flex h-8 w-8 shrink-0 items-center justify-center rounded-full text-sm {{ s.iconBg }}" aria-hidden="true">{{ s.icon }}</div>
    <div class="flex-1">
      <div class="mb-2 text-[10px] font-bold uppercase tracking-wider text-slate-600">{{ tag | safe }}</div>
      <div class="text-sm leading-relaxed text-slate-700">{{ caller() }}</div>
    </div>
  </div>
</aside>
{% endmacro %}

{# ---- bridge (Bridge.astro) -------------------------------------------- #}
{% macro bridge() %}
<div class="not-prose my-10 flex items-center gap-3 text-slate-500">
  <div class="h-px flex-1 bg-gradient-to-r from-transparent to-slate-300"></div>
  <p class="max-w-md text-center text-sm italic leading-relaxed">{{ caller() }}</p>
  <div class="h-px flex-1 bg-gradient-to-l from-transparent to-slate-300"></div>
</div>
{% endmacro %}

{# ---- demoFrame (DemoFrame.astro) -------------------------------------- #}
{% macro demoFrame(label, preview="", notice="") %}
<div class="demo-frame not-prose my-10">
  <div class="overflow-hidden rounded-2xl border border-slate-200 bg-white shadow-sm">
    <div class="flex items-start gap-3 border-b border-slate-100 bg-slate-50/70 px-5 py-3">
      <div class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-blue-100 text-xs font-bold text-blue-700" aria-hidden="true">▶</div>
      <div class="flex-1">
        <div class="text-[10px] font-bold uppercase tracking-wider text-blue-700">demo interactivo</div>
        <div class="text-sm font-bold text-slate-900">{{ label }}</div>
        {% if preview %}<p class="mt-1 text-sm leading-relaxed text-slate-500">{{ preview }}</p>{% endif %}
      </div>
    </div>
    <div class="p-5 sm:p-6">{{ caller() }}</div>
    {% if notice %}<div class="border-t border-slate-100 bg-amber-50/50 px-5 py-3 text-xs leading-relaxed text-amber-800"><span class="font-bold">o que reparar:</span> {{ notice }}</div>{% endif %}
  </div>
</div>
{% endmacro %}

{# ---- checkpointPrompt (CheckpointPrompt.astro) ------------------------- #}
{% macro checkpointPrompt(question, hint="") %}
<details class="not-prose group my-8 rounded-2xl border-2 border-purple-200 bg-gradient-to-br from-purple-50 to-white p-5">
  <summary class="flex cursor-pointer items-start gap-3 list-none">
    <span class="mt-0.5 flex h-7 w-7 shrink-0 items-center justify-center rounded-full bg-purple-600 text-sm font-bold text-white">?</span>
    <div class="flex-1">
      <div class="mb-1 text-[10px] font-bold uppercase tracking-wider text-purple-700">pausa · verifica em ti</div>
      <p class="text-base font-medium leading-relaxed text-slate-800">{{ question | safe }}</p>
      <div class="mt-2 text-xs font-medium text-purple-600 group-open:hidden">tens uma resposta? clica para ver pista →</div>
    </div>
  </summary>
  <div class="ml-10 mt-3 rounded-lg border border-purple-100 bg-white p-3 text-sm leading-relaxed text-slate-700">{% if hint %}{{ hint | safe }}{% else %}{{ caller() }}{% endif %}</div>
</details>
{% endmacro %}

{# ---- mariaCloser (MariaCloser.astro) ---------------------------------- #}
{% macro mariaCloser() %}
<aside class="not-prose my-8 overflow-hidden rounded-2xl border-2 border-amber-300 bg-gradient-to-br from-amber-50 to-white">
  <div class="flex items-start gap-4 p-5">
    <div class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-amber-200 text-2xl font-bold text-amber-900" aria-hidden="true">M</div>
    <div>
      <div class="mb-1 text-[10px] font-bold uppercase tracking-wider text-amber-700">e a Maria? · 64 anos · utente #1234</div>
      <p class="text-base leading-relaxed text-slate-800">{{ caller() }}</p>
    </div>
  </div>
</aside>
{% endmacro %}

{# ---- recap (Recap.astro) · 5 lessons hardcoded inside --------------- #}
{% macro recap() %}
{% set lessons = [
  "<strong>O modelo prevê a próxima palavra.</strong> Não compreende. Reconhece padrões aprendidos em biliões de frases — e tudo o que se segue vem desta limitação.",
  "<strong>Tudo o que disser pode ser fabricado.</strong> Citações, doses, guidelines. A fluência não é evidência. Verifica antes de assinar.",
  "<strong>Os vieses não desaparecem.</strong> Vêm dos dados. Se a coorte de treino exclui mulheres ou minorias, a saída exclui-as também, com a mesma confiança.",
  "<strong>RAG &gt; memória.</strong> Em uso clínico, um modelo apoiado em fontes externas (guidelines, literatura, normas <a href=\"https://www.dgs.pt/\" target=\"_blank\" rel=\"noopener\">DGS</a>, <a href=\"https://www.infarmed.pt/\" target=\"_blank\" rel=\"noopener\">INFARMED</a>) é muito mais fiável que o modelo a \"lembrar-se\".",
  "<strong>Delega por reversibilidade.</strong> Tarefas reversíveis: autonomia. Tarefas irreversíveis: revisão humana obrigatória. Prescrever, ajustar dose, decidir alta, validar uma interacção: nada disto é reversível."
] %}
<div class="not-prose my-8">
  <div class="mb-1 text-xs font-bold uppercase tracking-wider text-amber-700">cinco lições para levar</div>
  <ol class="space-y-3">
    {% for l in lessons %}
    <li class="flex gap-3 rounded-xl border-l-4 border-blue-500 bg-blue-50 p-4">
      <span class="font-mono text-sm font-bold text-blue-700">{% if loop.index < 10 %}0{% endif %}{{ loop.index }}</span>
      <span class="text-sm leading-relaxed text-slate-700">{{ l | safe }}</span>
    </li>
    {% endfor %}
  </ol>
</div>
{% endmacro %}

{# ---- dayMap (DayMap.astro) ------------------------------------------- #}
{% macro dayMap() %}
{% set steps = [
  { time: "07:30", title: "Sumário do turno", detail: "Antes de chegares, o sistema preparou um resumo dos utentes em internamento, mensagens novas no portal e tarefas pendentes. <a href=\"#agentes\">→ agentes</a>" },
  { time: "08:15", title: "Triagem e priorização", detail: "Mensagens, requisições, alertas farmacológicos, marcações. A IA pré-prioriza; tu (clínico, enfermeiro, farmacêutico) validas. <a href=\"#agentes\">→ agentes</a>" },
  { time: "09:00", title: "Encontro com o utente · scribe ambient", detail: "Consulta médica, avaliação de enfermagem, sessão de fisioterapia, intervenção psicológica — gravada e transcrita em nota estruturada. Olhas para a pessoa, não para o ecrã." },
  { time: "11:30", title: "Documentação clínica", detail: "Carta de alta, nota de evolução, plano de cuidados, relatório de fisioterapia, registo farmacêutico. Modelo gera rascunho; revês e assinas. <a href=\"#prompts\">→ prompts</a>" },
  { time: "14:00", title: "Codificação · interacções · planos", detail: "ICD-10 para internamentos, verificação de interacções para o farmacêutico, plano alimentar para o dietista, sequência de exercícios para o fisio. <a href=\"#tokens\">→ tokens</a>" },
  { time: "16:00", title: "Pesquisa de evidência", detail: "\"Que evidência há para esta abordagem em utentes com X?\" Resposta com referências verificáveis — útil em qualquer profissão. <a href=\"#rag\">→ RAG</a>" }
] %}
<div class="not-prose my-8">
  <div class="mb-1 text-xs font-bold uppercase tracking-wider text-blue-700">o teu turno · 2026</div>
  <h3 class="mb-1 text-2xl font-bold text-slate-900">Onde a IA já está, antes de discutirmos como funciona</h3>
  <ol class="mt-6 space-y-3">
    {% for s in steps %}
    <li class="flex gap-4 rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
      <div class="font-mono text-sm font-bold text-blue-600 sm:text-base">{{ s.time }}</div>
      <div class="flex-1">
        <div class="mb-1 font-bold text-slate-900">{{ s.title }}</div>
        <p class="text-sm leading-relaxed text-slate-600">{{ s.detail | safe }}</p>
      </div>
    </li>
    {% endfor %}
  </ol>
  <p class="mt-4 text-sm italic text-slate-500">Esta aula explica como cada um destes momentos funciona, e onde falha. Os exemplos clínicos variam consoante a profissão; o critério para usar IA com segurança é o mesmo.</p>
</div>
{% endmacro %}

{# ---- lectureSchema (LectureSchema.astro) ----------------------------- #}
{% macro lectureSchema() %}
{% set boxes = [
  { tag: "como nasce", title: "Pré-treino → SFT → RLHF", body: "Lê quase toda a internet (pré-treino). Aprende a obedecer com exemplos humanos (<a href=\"#treino\">SFT</a>). Afina-se por preferência (RLHF). Vocabulário em <a href=\"#tokens\">tokens</a>: em pt custa ~30 % mais." },
  { tag: "como funciona", title: "Prevê o próximo token, um a um", body: "<a href=\"#funciona\">Softmax sobre o vocabulário</a>; a temperatura controla a aleatoriedade. Sem compreensão e sem verificação: prevê o que vem a seguir." },
  { tag: "onde falha", title: "Alucinações · vieses", body: "Inventa <a href=\"#alucinacoes\">DOIs e estudos</a> com formato plausível. Reproduz <a href=\"#vieses\">enviesamentos</a> dos dados (idade, sexo, etnia). Fluência ≠ verdade." },
  { tag: "como melhora", title: "Prompts · RAG", body: "Bons <a href=\"#prompts\">prompts</a> reduzem ambiguidade. <a href=\"#rag\">RAG</a> dá-lhe fontes verificáveis em tempo real, cortando alucinações em 30–60 %." },
  { tag: "como actua", title: "Agentes (com humano à porta)", body: "Para além da conversa, <a href=\"#agentes\">marca consultas, lê processos e escreve cartas</a>. Cada acção crítica passa por gate humano de aprovação." },
  { tag: "sob que regras", title: "RGPD · responsabilidade humana", body: "<a href=\"#privacidade\">Anonimização real</a> (não só nome e data). A decisão final, e a assinatura, são do profissional responsável. Delegar por <a href=\"#quando\">reversibilidade</a>." }
] %}
<div class="not-prose my-8">
  <div class="mb-1 text-xs font-bold uppercase tracking-wider text-blue-700">esquema da aula</div>
  <h3 class="mb-1 text-2xl font-bold text-slate-900">O LLM clínico numa página</h3>
  <p class="mb-6 text-sm text-slate-600">Volta aqui quando te perderes. É a aula inteira em seis blocos.</p>
  <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {% for b in boxes %}
    <div class="rounded-xl border border-slate-200 bg-white p-4 shadow-sm">
      <div class="mb-1 text-xs font-bold uppercase tracking-wider text-slate-500">{{ b.tag }}</div>
      <div class="mb-2 font-bold text-slate-900">{{ b.title }}</div>
      <p class="text-sm leading-relaxed text-slate-600">{{ b.body | safe }}</p>
    </div>
    {% endfor %}
  </div>
  <p class="mt-4 text-xs italic text-slate-500">Carrega esta imagem para casa. Quando voltares a uma secção, pergunta: em que bloco do esquema isto encaixa?</p>
</div>
{% endmacro %}

{# ---- pathChooser (PathChooser.astro) --------------------------------- #}
{% macro pathChooser() %}
<div class="not-prose my-8 rounded-2xl border border-slate-200 bg-slate-50 p-5">
  <div class="mb-3 text-xs font-bold uppercase tracking-wider text-slate-500">primeira vez aqui? · escolhe o caminho</div>
  <div class="grid gap-3 sm:grid-cols-2">
    <a href="#historia" class="block rounded-xl border border-slate-200 bg-white p-4 transition hover:border-blue-400 hover:shadow">
      <div class="mb-1 font-bold text-slate-900">Estou a começar</div>
      <div class="text-sm text-slate-600">Caminho linear · todas as definições e checkpoints · ~75 min.</div>
    </a>
    <a href="#funciona" class="block rounded-xl border border-slate-200 bg-white p-4 transition hover:border-blue-400 hover:shadow">
      <div class="mb-1 font-bold text-slate-900">Já uso IA · quero ir ao essencial</div>
      <div class="text-sm text-slate-600">Atalhos para o que importa decidir amanhã.</div>
    </a>
  </div>
  <div class="mt-3 flex flex-wrap gap-2 text-xs">
    <span class="text-slate-500">Atalhos:</span>
    <a href="#prompts" class="text-blue-700 underline underline-offset-2 hover:no-underline">prompts</a>
    <a href="#alucinacoes" class="text-blue-700 underline underline-offset-2 hover:no-underline">alucinações</a>
    <a href="#rag" class="text-blue-700 underline underline-offset-2 hover:no-underline">RAG</a>
    <a href="#privacidade" class="text-blue-700 underline underline-offset-2 hover:no-underline">RGPD</a>
    <a href="#quando" class="text-blue-700 underline underline-offset-2 hover:no-underline">quando usar</a>
  </div>
</div>
{% endmacro %}

{# ---- profBridges (ProfBridges.astro) --------------------------------- #}
{% macro profBridges(enf="", farm="", psi="") %}
{% if enf or farm or psi %}
<div class="prof-bridges">
  {% if enf %}<div><strong>Enfermagem</strong><span>{{ enf | safe }}</span></div>{% endif %}
  {% if farm %}<div><strong>Farmácia</strong><span>{{ farm | safe }}</span></div>{% endif %}
  {% if psi %}<div><strong>Psicologia</strong><span>{{ psi | safe }}</span></div>{% endif %}
</div>
{% endif %}
{% endmacro %}

{# ---- facilitatorNote (FacilitatorNote.astro) ------------------------- #}
{% macro facilitatorNote(time="", wins="", confusion="", skip="", prompt="") %}
<aside class="facilitator-notes" aria-hidden="true">
  {% if time %}<div><strong>Tempo:</strong> {{ time }}</div>{% endif %}
  {% if wins %}<div><strong>Wins:</strong> {{ wins }}</div>{% endif %}
  {% if confusion %}<div><strong>Confusão típica:</strong> {{ confusion }}</div>{% endif %}
  {% if skip %}<div><strong>Cortar se rushed:</strong> {{ skip }}</div>{% endif %}
  {% if prompt %}<div><strong>Prompt de discussão:</strong> {{ prompt }}</div>{% endif %}
</aside>
{% endmacro %}

{# ---- term (Term.astro) · inline glossary span ------------------------ #}
{# Glossary lookup uses the {{ glossary }} _data global. Popover is wired
   in chrome.js by reading window.__IA_GLOSSARY (injected by main.njk). #}
{% macro term(k, label="") %}
{% set entry = glossary[k] %}
<span class="gloss-term inline" data-term="{{ k }}" tabindex="0" role="button" aria-label="definição: {{ entry.term if entry else k }}">{% if label %}{{ label }}{% elif entry %}{{ entry.term }}{% else %}{{ k }}{% endif %}{% if entry %}<span class="sr-only">: {{ entry.def }}</span>{% endif %}</span>
{% endmacro %}
